CONFIG_TARGET_ipq60xx=y
CONFIG_TARGET_ipq60xx_generic=y
CONFIG_TARGET_ipq60xx_generic_DEVICE_xiaomi_ax1800=y

# 取消所有 Wi-Fi 相关
# CONFIG_PACKAGE_kmod-ath11k is not set
# CONFIG_PACKAGE_ath11k-firmware-ipq6018 is not set
# CONFIG_PACKAGE_wpad-mbedtls is not set

# 取消所有 NSS 加速相关
# CONFIG_PACKAGE_kmod-qca-nss-drv is not set
# CONFIG_PACKAGE_kmod-qca-nss-ecm is not set
# CONFIG_PACKAGE_nss-firmware-ipq60xx is not set

# 必须增加的工具，确保 sing-box 运行
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_zram-swap=y
